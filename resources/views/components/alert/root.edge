@let(variant = $props.get('variant') || 'default')
@inject({ variant, autoDismiss: $props.get('autoDismiss') })
@let(classes = ['alert', `alert-${variant}`])

<div {{
  $props
    .except(['variant', 'autoDismiss'])
    .merge({
      role: 'alert',
      class: classes,
      'x-data': 'alert',
      'x-show': 'isVisible',
      'x-cloak': true,
    })
    .toAttrs()
}}>
  <span class="alert-icon"></span>
  {{{ await $slots.main() }}}
</div>
