    <meta name="description" content="{{ description || 'PolyPress, la plateforme de publication anonyme du club journal de l\'ENSPY. Partage tes anecdotes de vie poly en toute discrétion.' }}" />
    <meta name="theme-color" content="#0f2d5a" />

    {{-- Open Graph --}}
    <meta property="og:title" content="{{ title || 'PolyPress — Pipo life, Pipo news' }}" />
    <meta property="og:description" content="{{ description || 'Partage tes anecdotes de vie poly en toute discrétion. Le club journal de l\'ENSPY.' }}" />
    <meta property="og:image" content="/public/images/logo.jpeg" />
    <meta property="og:type" content="website" />

    {{-- Favicon (emoji provisoire) --}}
