  <body>

    {{-- ╔══════════════════════════════════════╗
         ║            NAVBAR                    ║
         ╚══════════════════════════════════════╝ --}}
    <nav class="pp-navbar" role="navigation" aria-label="Navigation principale">
      <div class="pp-navbar__inner">

        {{-- Marque / Logo --}}
        <a href="/" class="pp-navbar__brand" aria-label="PolyPress — Accueil">
          {{-- Colibri origami SVG minimaliste --}}
          <img src="/public/images/logo.jpeg" alt="PolyPress" class="pp-navbar__logo" width="28" height="28"/>
          PolyPress
        </a>

        {{-- Liens de nav (desktop) --}}
        <ul class="pp-navbar__links" id="pp-nav-links" role="list">
          <li><a href="/messages" id="nav-feed">Anecdotes</a></li>
          @if(auth.user)
            <li><a href="/admin" id="nav-admin" style="color: var(--orange); font-weight: 700;">Console Admin</a></li>
          @endif
          <li><a href="#comment" id="nav-comment">Comment ça marche</a></li>
          <li><a href="#contact" id="nav-contact">Contact</a></li>
        </ul>

        {{-- CTA navbar / User profile --}}
        <div class="pp-navbar__actions-container" style="display: flex; align-items: center; gap: 0.75rem;">
          <a href="/messages/create" class="pp-btn pp-btn--outline pp-navbar__cta" id="nav-cta-btn">
            ✍️ Se confesser
          </a>

          @if(auth.user)
            <div class="pp-navbar__user" style="display: flex; align-items: center; gap: 0.5rem; font-size: 0.85rem; font-weight: 600;">
              @!avatar({ initials: auth.user.initials })
            </div>
            @form({ route: 'session.destroy', method: 'POST', style: 'display: inline;' })
              <button type="submit" class="pp-btn pp-btn--outline" style="border-color: var(--text-muted); color: var(--text-muted); padding: 0.4rem 1rem; font-size: 0.8rem;" id="nav-logout-btn">
                Déconnexion
              </button>
            @end
          @endif
        </div>

        {{-- Bouton hamburger (mobile) --}}
        <button class="pp-navbar__toggle" id="pp-hamburger" aria-label="Ouvrir le menu" aria-expanded="false" aria-controls="pp-nav-links">
          <span></span>
          <span></span>
          <span></span>
        </button>

      </div>
    </nav>

    {{-- Contenu de la page --}}
    <main>
